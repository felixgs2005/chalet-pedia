rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /listings/{collection}/{listingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /services/listings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
