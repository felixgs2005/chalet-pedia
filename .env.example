# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=          (mot de passe d'application Gmail)
# SMTP_FROM=info@chaletpedia.com
# APP_ORIGIN=https://chalet-pedia.vercel.app
# Courriel admin (notifications + dashboard) : src/config/adminEmail.json

# Stripe — Cloud Functions (variables d'environnement) :
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_CHALETS=price_...     (90 $/an récurrent — prélèvement automatique)
# STRIPE_PRICE_SERVICES=price_...      (45 $/an récurrent — prélèvement automatique)
# Webhook Stripe → URL de la fonction stripeWebhook (mode subscription)
