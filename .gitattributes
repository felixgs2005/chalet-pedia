# Normaliser les fins de ligne (évite les faux "modified" sur Windows).
* text=auto eol=lf

# Scripts Windows : conserver CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaires : ne pas toucher.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
