# Copiez ce fichier vers .env à la racine de chalet-pedia/ et remplissez avec
# Firebase Console → Paramètres du projet → Vos applications → Config SDK

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# STORAGE_BUCKET : Storage → onglet Files (ex. chaletpedia.firebasestorage.app)
# Pas de guillemets autour des valeurs.
