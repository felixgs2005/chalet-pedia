rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAvisStatsUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['note', 'nombreAvis']);
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == 'wintechnologie830@gmail.com';
    }

    function isAdminListingUpdate() {
      return isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['statut', 'datePublication', 'dateRefus']);
    }

    function isListingOwner() {
      return !('proprietaireId' in resource.data)
        || resource.data.proprietaireId == request.auth.uid;
    }

    function isOwnerListingUpdate() {
      return isListingOwner()
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['statut', 'datePublication', 'dateRefus']);
    }

    function isPendingStatutOnCreate() {
      return !('statut' in request.resource.data)
        || request.resource.data.statut in ['En attente', 'en attente', 'en_attente', 'pending'];
    }

    match /chalets/{chaletId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid
        && isPendingStatutOnCreate();
      allow update: if request.auth != null
        && (
          isAvisStatsUpdate()
          || isAdminListingUpdate()
          || isOwnerListingUpdate()
        );
    }

    match /ventes/{venteId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid
        && isPendingStatutOnCreate();
      allow update: if request.auth != null
        && (
          isAvisStatsUpdate()
          || isAdminListingUpdate()
          || isOwnerListingUpdate()
        );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !('role' in request.resource.data);
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    match /categorieServices/{categoryId} {
      allow read: if true;
      match /annoncesService/{listingId} {
        allow read: if true;
        allow create: if request.auth != null
          && (!('proprietaireId' in request.resource.data)
              || request.resource.data.proprietaireId == request.auth.uid)
          && isPendingStatutOnCreate();
        allow update: if request.auth != null
          && (isAdminListingUpdate() || isOwnerListingUpdate());
      }
    }

    match /avis/{avisId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /favoris/{favoriId} {
      allow read: if request.auth != null
        && resource.data.utilisateur.uid == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.utilisateur.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.utilisateur.uid == request.auth.uid;
    }

    match /signalements/{signalementId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /contactMessages/{messageId} {
      allow create: if request.resource.data.nom is string
        && request.resource.data.nom.size() > 0
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.consentement == true
        && (!('telephone' in request.resource.data) || request.resource.data.telephone is string);
      allow read, update, delete: if false;
    }

    match /listingContactMessages/{messageId} {
      allow create: if request.resource.data.nom is string
        && request.resource.data.nom.size() > 0
        && request.resource.data.email is string
        && request.resource.data.telephone is string
        && request.resource.data.telephone.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.consentement == true
        && request.resource.data.typeEntite is string
        && request.resource.data.entiteId is string
        && (!('categorieSlug' in request.resource.data) || request.resource.data.categorieSlug is string);
      allow read, update, delete: if false;
    }

    match /passwordResetCodes/{emailKey} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read: if true;
    }
  }
}
