rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /chalets/{chaletId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid;
      allow update: if request.auth != null
        && (
          !('proprietaireId' in resource.data)
          || resource.data.proprietaireId == request.auth.uid
        );
    }

    match /ventes/{venteId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid;
      allow update: if request.auth != null
        && (
          !('proprietaireId' in resource.data)
          || resource.data.proprietaireId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /categorieServices/{categoryId} {
      allow read: if true;
      match /annoncesService/{listingId} {
        allow read: if true;
        allow create, update: if request.auth != null;
      }
    }

    match /avis/{avisId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /{document=**} {
      allow read: if true;
    }
  }
}
