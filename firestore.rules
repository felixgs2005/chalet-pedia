rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /chalets/{chaletId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid;
      allow update: if request.auth != null
        && (
          !('proprietaireId' in resource.data)
          || resource.data.proprietaireId == request.auth.uid
        );
    }

    match /ventes/{venteId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid;
      allow update: if request.auth != null
        && (
          !('proprietaireId' in resource.data)
          || resource.data.proprietaireId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /categorieServices/{categoryId} {
      allow read: if true;
      match /annoncesService/{listingId} {
        allow read: if true;
        allow create, update: if request.auth != null;
      }
    }

    match /avis/{avisId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /messages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.expediteur.uid == request.auth.uid;
    }

    match /favoris/{favoriId} {
      allow read: if request.auth != null
        && resource.data.utilisateur.uid == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.utilisateur.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.utilisateur.uid == request.auth.uid;
    }

    match /signalements/{signalementId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Extension Firebase « Trigger Email from Firestore »
    match /mail/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read: if true;
    }
  }
}
