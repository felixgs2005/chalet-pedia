rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAvisStatsUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['note', 'nombreAvis']);
    }

    match /chalets/{chaletId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid;
      allow update: if request.auth != null
        && (
          isAvisStatsUpdate()
          || !('proprietaireId' in resource.data)
          || resource.data.proprietaireId == request.auth.uid
        );
    }

    match /ventes/{venteId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.proprietaireId == request.auth.uid;
      allow update: if request.auth != null
        && (
          isAvisStatsUpdate()
          || !('proprietaireId' in resource.data)
          || resource.data.proprietaireId == request.auth.uid
        );
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /categorieServices/{categoryId} {
      allow read: if true;
      match /annoncesService/{listingId} {
        allow read: if true;
        allow create, update: if request.auth != null;
      }
    }

    match /avis/{avisId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /messages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.expediteur.uid == request.auth.uid;
    }

    match /favoris/{favoriId} {
      allow read: if request.auth != null
        && resource.data.utilisateur.uid == request.auth.uid;
      allow create, update: if request.auth != null
        && request.resource.data.utilisateur.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.utilisateur.uid == request.auth.uid;
    }

    match /signalements/{signalementId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Booking reservations
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Extension Firebase « Trigger Email from Firestore »
    match /mail/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Formulaire contact — création publique ; envoi courriel via Cloud Function
    match /contactMessages/{messageId} {
      allow create: if request.resource.data.nom is string
        && request.resource.data.nom.size() > 0
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.consentement == true
        && (!('telephone' in request.resource.data) || request.resource.data.telephone is string);
      allow read, update, delete: if false;
    }

    // Modale « Contacter l'annonceur » — envoi courriel propriétaire via Cloud Function
    match /listingContactMessages/{messageId} {
      allow create: if request.resource.data.nom is string
        && request.resource.data.nom.size() > 0
        && request.resource.data.email is string
        && request.resource.data.telephone is string
        && request.resource.data.telephone.size() > 0
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.consentement == true
        && request.resource.data.typeEntite is string
        && request.resource.data.entiteId is string
        && (!('categorieSlug' in request.resource.data) || request.resource.data.categorieSlug is string);
      allow read, update, delete: if false;
    }

    match /{document=**} {
      // Restrict blanket read access by default. Permit specific collections above.
      allow read: if false;
    }
  }
}
